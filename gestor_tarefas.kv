#:kivy 2.0

<TarefasLayout>:
    orientation: "vertical"
    padding: 10
    spacing: 10

    TextInput:
        id: nome
        hint_text: "Nome da Tarefa"
        size_hint_y: None
        height: 40

    TextInput:
        id: info
        hint_text: "Informação"
        size_hint_y: None
        height: 40

    TextInput:
        id: data
        hint_text: "Data (DD/MM/YYYY)"
        size_hint_y: None
        height: 40

    BoxLayout:
        size_hint_y: None
        height: 50
        spacing: 10

        Button:
            text: "Adicionar"
            on_press: root.adicionar_tarefa()

        Button:
            text: "Remover Última"
            on_press: root.remover_tarefa()

    RecycleView:
        id: lista
        viewclass: "Label"
        RecycleBoxLayout:
            orientation: "vertical"
            default_size: None, 40
            default_size_hint: 1, None
            size_hint_y: None
            height: self.minimum_height